# BizPilot AI - Environment Variables
# Copy to .env and adjust as needed

# CrewAI / LLM - Required for agents (OpenAI by default)
OPENAI_API_KEY=your_openai_api_key_here

# Database - SQLite for MVP, use PostgreSQL URL for production
# DATABASE_URL=sqlite:///./bizpilot.db
# DATABASE_URL=postgresql://user:password@localhost:5432/bizpilot

# Redis - For caching and task queues (future use)
# REDIS_URL=redis://localhost:6379/0

# ChromaDB - For vector embeddings (future use)
# CHROMADB_PATH=./chroma_db

# API
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# CORS - Comma-separated origins for frontend
CORS_ORIGINS=http://localhost:3000
